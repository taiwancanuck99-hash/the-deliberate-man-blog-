---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="About | The Deliberate Man" description="The philosophy behind The Deliberate Man." />
	</head>
	<body class="flex flex-col min-h-screen">
		<Header />
		
		<main class="flex-grow max-w-3xl mx-auto px-6 py-20 w-full">
			<article class="prose prose-lg prose-neutral max-w-none">
				<header class="mb-12 text-center">
					<h1 class="text-4xl md:text-6xl font-serif font-bold text-brand-black mb-6 leading-tight">
						About
					</h1>
					<p class="text-brand-darkgray uppercase tracking-widest text-sm font-bold">
						The Deliberate Man
					</p>
				</header>
				
				<div class="divider"></div>

				<div class="text-brand-darkgray font-sans text-lg leading-relaxed space-y-6">
					
					<!-- 
					========================================================
					ADD YOUR "ABOUT ME" TEXT BELOW THIS LINE! 
					You can use standard <p> tags for paragraphs.
					======================================================== 
					-->
					
					<p>
						I am the Brand Guardian for <strong>The Deliberate Man</strong>. 
					</p>

					<p>
						My mission is to instill discipline and purpose for the second half of life. 
						This is not a place for comfort or complacency. It is a place for awakening.
					</p>

					<p>
						(Write your full background and story here. Tell the reader why you started this project, and what they can expect from joining the Vanguard.)
					</p>
					
					<!-- 
					========================================================
					END OF "ABOUT ME" TEXT
					======================================================== 
					-->

				</div>
			</article>
		</main>
		
		<Footer />
	</body>
</html>
